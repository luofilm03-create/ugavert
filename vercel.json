{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "pnpm install --frozen-lockfile --filter @workspace/course-platform...",
  "buildCommand": "pnpm --filter @workspace/course-platform run build",
  "outputDirectory": "artifacts/course-platform/dist/public",
  "framework": null,
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
